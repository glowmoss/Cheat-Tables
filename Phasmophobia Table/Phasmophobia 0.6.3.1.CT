  <UserdefinedSymbols/>
  <LuaScript>--If asked let the script run. I would recommend letting signed tables execute code





getAutoAttachList().add("Phasmophobia.exe")




local mForm = getMainForm()
local App = getApplication()

  mForm.Caption="Phasmophobia CT"
  App.title="Phasmophobia CT"


if not getProcessIDFromProcessName("Phasmophobia.exe") then
  if messageDialog( "Open Phasmophobia Now?", mtConfirmation, mbYes, mbNo ) == mrYes then

  ShellExecute("steam://rungameid/739630")

  end
end


--compact mode
  function cycleFullCompact( sender, force )
    local state = not( compactmenuitem.Caption == 'Small' )
    if force ~= nil then
      state = not force
    end
    compactmenuitem.Caption = state and 'Small' or 'Full'
    getMainForm().Splitter1.Visible = state
    getMainForm().Panel5.Visible = state
  end

  function addCompactMenu()
    if compactmenualreadyexists then return end
      local parent = getMainForm().Menu.Items
      compactmenuitem = createMenuItem( parent )
      parent.add( compactmenuitem )
      compactmenuitem.Caption = 'Small'
      compactmenuitem.OnClick = cycleFullCompact
      compactmenualreadyexists = 'yes'
  end

  addCompactMenu()
  cycleFullCompact( nil, True )

local TABLE_VERSION = 1.0

local version_url = "https://github.com/glowmoss/Cheat-Tables/blob/main/Phasmophobia%20Table/Version.txt"

local http = getInternet()

local result = http.getURL(version_url)

if result then

  local version = tonumber(result:match("%d+"))

  if version &gt; TABLE_VERSION then

    local stream = createStringStream(getInternet().getURL('https://github.com/glowmoss/Cheat-Tables/blob/main/Phasmophobia%20Table/Phasmophobia%200.6.3.1.CT'))
loadTable(stream)
stream.destroy()
    end

else

  messageDialog("Failed to find latest version!", mtError, mbOK)

end

http.destroy()


